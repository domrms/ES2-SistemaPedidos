{
  "AWS": {
    "Regiao": "us-east-1",
    "FilaSolicitacoesUrl": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "ES2_SistemaPedidos.Shared.Logging.DateTimeConsoleFormatter, ES2-SistemaPedidos.Shared"
        }
      }
    ]
  }
}
